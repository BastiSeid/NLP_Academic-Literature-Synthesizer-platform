# ─────────────────────────────────────────────────────────────────────────────
# Academic Literature Synthesizer — backend configuration
# Copy to `.env` and adjust. All external data sources are READ-ONLY and free;
# no source API key is required to run. Keys below are OPTIONAL enhancers only.
# ─────────────────────────────────────────────────────────────────────────────

# --- Agent runtime (Claude Max subscription via the `claude` CLI) -------------
# The platform's six agents are powered by your Claude Max subscription by
# shelling out to the `claude` CLI in headless mode. No API key needed for this
# path — the CLI uses your existing Max login.
LITSYNTH_MODEL=claude-opus-4-8
# Absolute path to the claude CLI if not on PATH (default: "claude")
LITSYNTH_CLAUDE_BIN=claude
# Per-agent-call wall-clock timeout (seconds)
LITSYNTH_AGENT_TIMEOUT=300

# Optional fallback: if set, and the CLI path fails, the runner uses the
# Anthropic API directly. Leave blank to stay on the Max subscription only.
ANTHROPIC_API_KEY=

# --- Run guardrails (defaults; per-run params can override in the UI) ---------
# Hard ceiling on cumulative USD cost per run. Run halts (kill switch) if hit.
LITSYNTH_COST_CAP_USD=40
# Wall-clock timeout for an entire run (seconds).
LITSYNTH_RUN_TIMEOUT=3600
# Max pipeline steps before forced stop (loop backstop).
LITSYNTH_MAX_STEPS=200

# --- Data sources (read-only; all free, no key required) ----------------------
# OpenAlex "polite pool" email — recommended for higher rate limits, not required.
LITSYNTH_OPENALEX_EMAIL=
# Semantic Scholar API key — optional, raises rate limits. Free sources work without it.
SEMANTIC_SCHOLAR_API_KEY=

# --- Storage ------------------------------------------------------------------
# SQLite datastore path (created on first run).
LITSYNTH_DB_PATH=./litsynth.db
# Default export directory for assembled deliverables (UI can override per run).
LITSYNTH_EXPORT_DIR=./exports
